<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <head>
        <css src="Pronko_CacheToolbar::css/cache-toolbar.css"/>
    </head>
    <body>
        <referenceContainer name="global.notices">
            <block name="pronko.cache.toolbar"
                   class="Magento\Backend\Block\Template"
                   template="Pronko_CacheToolbar::toolbar.phtml"
                   after="-">
                <arguments>
                    <argument name="view_model" xsi:type="object">Pronko\CacheToolbar\ViewModel\Toolbar</argument>
                </arguments>
                <block name="pronko.cache.promo"
                       class="Magento\Backend\Block\Template"
                       template="Pronko_CacheToolbar::promo.phtml"/>
            </block>
        </referenceContainer>
    </body>
</page>
