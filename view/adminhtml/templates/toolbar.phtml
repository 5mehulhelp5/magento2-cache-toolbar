<?php
declare(strict_types=1);

use Magento\Framework\Escaper;
use Pronko\CacheToolbar\ViewModel\Toolbar;

/** @var \Magento\Backend\Block\Template $block */
/** @var Toolbar $viewModel */
/** @var Escaper $escaper */

$viewModel = $block->getData('view_model');

if (!$viewModel->isEnabled() || !$viewModel->canClear()) {
    return;
}

$isOutdated     = $viewModel->isOutdated();
$invalidated    = $viewModel->getInvalidatedTypes();
$typeLabels     = $viewModel->getTypeLabels();
$initialState   = $isOutdated ? 'outdated' : 'hidden';
$initialClass   = $isOutdated ? 'pronko-cache-toolbar--outdated' : 'pronko-cache-toolbar--hidden';
$typeLabel      = $isOutdated
    ? implode(', ', array_map(fn($code) => $typeLabels[$code] ?? $code, $invalidated))
    : '';
$initialMessage = $isOutdated
    ? (string) __('Cache invalidated%1 — clear now?', $typeLabel ? ' (' . $typeLabel . ')' : '')
    : (string) __('Cache is invalidated.');
?>
<div class="pronko-cache-toolbar <?= $escaper->escapeHtmlAttr($initialClass) ?>"
     id="pronko-cache-toolbar"
     data-state="<?= $escaper->escapeHtmlAttr($initialState) ?>"
     data-smart-clear-url="<?= $escaper->escapeHtmlAttr($viewModel->getSmartClearUrl()) ?>"
     data-full-clear-url="<?= $escaper->escapeHtmlAttr($viewModel->getFullClearUrl()) ?>"
     data-shortcut-enabled="<?= $viewModel->isShortcutEnabled() ? '1' : '0' ?>"
     data-form-key="<?= $escaper->escapeHtmlAttr($block->getFormKey()) ?>">
    <div class="pronko-cache-toolbar__inner">
        <span class="pronko-cache-toolbar__icon" id="pronko-cache-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                <path d="M20 11a8.1 8.1 0 0 0 -15.5 -2m-.5 -4v4h4"/>
                <path d="M4 13a8.1 8.1 0 0 0 15.5 2m.5 4v-4h-4"/>
            </svg>
        </span>
        <span class="pronko-cache-toolbar__message" id="pronko-cache-message" role="status" aria-live="polite">
            <?= $escaper->escapeHtml($initialMessage) ?>
        </span>
        <div class="pronko-cache-toolbar__actions" id="pronko-cache-actions">
            <button type="button" class="pronko-cache-toolbar__button pronko-cache-toolbar__button--smart" id="pronko-smart-clear">
                <?= $escaper->escapeHtml(__('Smart Clear')) ?>
            </button>
            <button type="button" class="pronko-cache-toolbar__button pronko-cache-toolbar__button--full" id="pronko-full-clear">
                <?= $escaper->escapeHtml(__('Full Clear')) ?>
            </button>
        </div>
        <button type="button" class="pronko-cache-toolbar__dismiss" id="pronko-cache-dismiss" title="<?= $escaper->escapeHtmlAttr(__('Dismiss')) ?>">&#x2715;</button>
        <span class="pronko-cache-toolbar__spinner" id="pronko-cache-spinner" aria-hidden="true"></span>
    </div>
</div>
<?php if ($viewModel->isPromoEnabled()): ?>
<?= $block->getChildHtml('pronko.cache.promo') ?>
<?php endif; ?>
<script>
require(['Pronko_CacheToolbar/js/cache-toolbar']);
</script>
